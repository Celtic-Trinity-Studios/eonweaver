{
    "name": "eon-weaver",
    "version": "2.0.0",
    "description": "Eon Weaver — AI-powered D&D campaign manager",
    "type": "module",
    "scripts": {
        "dev": "node ./node_modules/vite/bin/vite.js",
        "build": "node ./node_modules/vite/bin/vite.js build --config vite.config.live.js",
        "postbuild": "node -e \"require('fs').copyFileSync('.htaccess','live/.htaccess')\"",
        "build:dev": "node ./node_modules/vite/bin/vite.js build",
        "preview": "node ./node_modules/vite/bin/vite.js preview --config vite.config.live.js",
        "preview:dev": "node ./node_modules/vite/bin/vite.js preview"
    },
    "devDependencies": {
        "sql.js": "^1.14.0",
        "vite": "^6.0.0"
    },
    "dependencies": {
        "basic-ftp": "^6.0.1",
        "pdf-lib": "^1.17.1"
    }
}
