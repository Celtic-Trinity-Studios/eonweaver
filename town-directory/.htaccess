php_value max_execution_time 300
php_value memory_limit 256M

# SPA routing — serve index.html for non-file, non-directory requests
# BUT skip .js, .css, and other static assets so dynamic imports work
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.(js|css|gif|jpg|jpeg|png|ico|json|txt|woff|woff2|svg|webp|map)$ [NC]
RewriteRule ^ index.html [L]
