# Copy to deploy.env (gitignored). Used by deploy.cjs and deploy_worldscribe.ps1.
# NEVER commit deploy.env — it holds FTP passwords.
#
# deploy.cjs and deploy_worldscribe.ps1 use different hosting accounts — before each
# deploy, ensure deploy.env has the EW_FTP_* values for THAT target (or keep two
# copies locally e.g. deploy.eon.env / deploy.ws.env and copy over).

EW_FTP_HOST=your.ftp.host
EW_FTP_USER=your_ftp_username
EW_FTP_PASS=your_ftp_password
# Optional: "true" for FTPS (if your host supports it)
EW_FTP_SECURE=false
